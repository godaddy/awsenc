<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package
        Name="awsenc"
        Manufacturer="Jay Gowdy"
        Version="!(bind.FileVersion.awsenc.exe)"
        UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
        Scope="perUser">

        <MajorUpgrade
            DowngradeErrorMessage="A newer version of awsenc is already installed." />

        <MediaTemplate EmbedCab="yes" />

        <!-- Install directory -->
        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="INSTALLFOLDER" Name="awsenc">
                <Directory Id="BinFolder" Name="bin" />
            </Directory>
        </StandardDirectory>

        <!-- Files -->
        <ComponentGroup Id="ProductComponents" Directory="BinFolder">
            <Component Id="awsenc_exe">
                <File Id="awsenc.exe" Source="dist\awsenc.exe" KeyPath="yes" />
            </Component>
            <Component Id="awsenc_tpm_bridge_exe">
                <File Id="awsenc_tpm_bridge.exe" Source="dist\awsenc-tpm-bridge.exe" KeyPath="yes" />
            </Component>
            <Component Id="linux_binary">
                <File Id="awsenc_linux" Source="dist\awsenc-linux" KeyPath="yes" />
            </Component>

            <!-- Add to user PATH -->
            <Component Id="PathEntry">
                <Environment
                    Id="PATH"
                    Name="PATH"
                    Value="[BinFolder]"
                    Permanent="no"
                    Part="last"
                    Action="set"
                    System="no" />
                <RegistryValue
                    Root="HKCU"
                    Key="Software\awsenc"
                    Name="PathSet"
                    Type="integer"
                    Value="1"
                    KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <!-- Feature -->
        <Feature Id="MainFeature" Title="awsenc" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>

        <!-- Custom actions: run awsenc install after install, awsenc uninstall before uninstall -->
        <CustomAction
            Id="AwsencInstall"
            FileRef="awsenc.exe"
            ExeCommand="install"
            Execute="deferred"
            Impersonate="yes"
            Return="ignore" />

        <CustomAction
            Id="AwsencUninstall"
            FileRef="awsenc.exe"
            ExeCommand="uninstall"
            Execute="deferred"
            Impersonate="yes"
            Return="ignore" />

        <InstallExecuteSequence>
            <Custom Action="AwsencInstall" After="InstallFiles" Condition="NOT REMOVE" />
            <Custom Action="AwsencUninstall" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
        </InstallExecuteSequence>

    </Package>
</Wix>
